# 大模型配置：不填写 OPENAI_API_KEY 时自动使用离线教学桩。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=mock-llm

# Docker Compose image tag. GitHub Actions deployment sets this to the 40-character commit SHA.
IMAGE_TAG=dev

# 后续实验使用的三个微服务地址。
# Docker Compose automatically replaces these localhost URLs with internal service DNS names.
ITEM_URL=http://localhost:8001
CLAIM_URL=http://localhost:8002
HANDOVER_URL=http://localhost:8003

# 后续实验的 RAG 检索条数。
POLICY_K=2

